# ============================================
# UserIn MCP Server — Configuracao
# ============================================
# Copie para .env e preencha os valores.
# O JWT e companyId sao obtidos automaticamente via tool login(email, password).
#
# Para servicos em Contabo, crie SSH tunnels:
# ssh -L 3055:127.0.0.1:3055 -L 3066:127.0.0.1:3066 -L 3077:127.0.0.1:3077 -L 8090:127.0.0.1:8090 user@CONTABO_IP

# URLs dos servicos
PLATFORM_URL=https://api.upstore.ai
SEGMENTS_URL=http://localhost:3055
AI_JOURNEY_URL=http://localhost:8090
INTEGRATIONS_URL=http://localhost:3066
INGESTION_URL=http://localhost:3077
CREATEFLOW_URL=http://localhost:4000
FLOWIMAGER_URL=http://localhost:4001

# Secrets para comunicacao entre servicos (nao mude a menos que saiba o que faz)
INTERNAL_SECRET=userin-internal-2024
API_SECRET=userinsight_secret_key_2023
JWT_SECRET=userinsight_secret_key_2024
INGESTION_API_KEY=
